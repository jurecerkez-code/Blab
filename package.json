{
  "name": "blab",
  "private": true,
  "version": "0.2.0",
  "description": "Record a talk, type notes, get a transcript. All on your own machine.",
  "author": "jurecerkez-code",
  "license": "MIT",
  "repository": { "type": "git", "url": "https://github.com/jurecerkez-code/Blab.git" },
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "setup": "node scripts/setup.mjs",
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "icon": "node scripts/icon.mjs",
    "app": "npm run build && electron .",
    "app:dev": "electron . --dev",
    "app:check": "electron . --diagnose",
    "package": "npm run build && npm run icon && node scripts/package.mjs"
  },
  "build": {
    "appId": "app.blab.local",
    "productName": "Blab",
    "asar": false,
    "files": [
      "dist/**",
      "electron/**",
      "package.json",
      "!node_modules/**"
    ],
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": "universal"
        }
      ],
      "icon": "build/icon.png",
      "category": "public.app-category.productivity",
      "identity": "-",
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Blab records audio so it can transcribe it on this machine."
      }
    },
    "dmg": {
      "artifactName": "Blab-${version}.${ext}"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Blab",
      "artifactName": "Blab-Setup-${version}.${ext}"
    }
  },
  "dependencies": {
    "@huggingface/transformers": "3.7.6"
  },
  "devDependencies": {
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "typescript": "5.9.3",
    "vite": "^7.3.6"
  }
}
