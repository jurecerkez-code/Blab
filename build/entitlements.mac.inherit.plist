<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Electron does the actual audio capture in a helper process, not in Blab
       itself. Without this key each helper looks like its own application to
       macOS — one with no name the user recognises and no reason given for
       wanting a microphone — so the request dies there. Inheriting hands the
       helper the permission the user granted to Blab. -->
  <key>com.apple.security.inherit</key>
  <true/>

  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>
</dict>
</plist>
